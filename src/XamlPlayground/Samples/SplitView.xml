<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Border>
    <Grid ColumnDefinitions="*,225">
      <StackPanel Grid.Column="1" Orientation="Vertical" Spacing="4" Margin="5">
        <ToggleButton Content="IsPaneOpen" IsChecked="{Binding #SplitView.IsPaneOpen, Mode=TwoWay}" />
        <TextBlock Text="DisplayMode" />
        <ComboBox Width="170" SelectedIndex="1" IsEnabled="False">
          <ComboBoxItem>Inline</ComboBoxItem>
          <ComboBoxItem>CompactInline</ComboBoxItem>
          <ComboBoxItem>Overlay</ComboBoxItem>
          <ComboBoxItem>CompactOverlay</ComboBoxItem>
        </ComboBox>
        <TextBlock Text="{Binding #OpenPaneLengthSlider.Value, StringFormat='OpenPaneLength: {0:F0}'}" />
        <Slider Name="OpenPaneLengthSlider" Value="220" Minimum="128" Maximum="500" Width="150" />
        <TextBlock Text="{Binding #CompactPaneLengthSlider.Value, StringFormat='CompactPaneLength: {0:F0}'}" />
        <Slider Name="CompactPaneLengthSlider" Value="48" Minimum="24" Maximum="128" Width="150" />
      </StackPanel>

      <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" BorderThickness="1">
        <SplitView Name="SplitView"
                   IsPaneOpen="True"
                   PanePlacement="Left"
                   DisplayMode="CompactInline"
                   OpenPaneLength="{Binding #OpenPaneLengthSlider.Value}"
                   CompactPaneLength="{Binding #CompactPaneLengthSlider.Value}">
          <SplitView.Pane>
            <Grid RowDefinitions="Auto,Auto,*,Auto">
              <TextBlock Text="PANE CONTENT" FontWeight="Bold" Margin="5,12,0,0" />
              <ComboBox Width="150" Grid.Row="1">
                <ComboBoxItem Content="Item1" />
                <ComboBoxItem Content="Item2" />
                <ComboBoxItem Content="Item3" />
              </ComboBox>
              <ListBoxItem Grid.Row="2" VerticalAlignment="Top" Margin="0 10">
                <StackPanel Orientation="Horizontal">
                  <Border Width="48">
                    <Viewbox Width="24" Height="24" HorizontalAlignment="Left">
                      <Canvas Width="24" Height="24">
                        <Path Fill="{DynamicResource SystemControlForegroundBaseHighBrush}" Data="M16 17V19H2V17S2 13 9 13 16 17 16 17M12.5 7.5A3.5 3.5 0 1 0 9 11A3.5 3.5 0 0 0 12.5 7.5M15.94 13A5.32 5.32 0 0 1 18 17V19H22V17S22 13.37 15.94 13M15 4A3.39 3.39 0 0 0 13.07 4.59A5 5 0 0 1 13.07 10.41A3.39 3.39 0 0 0 15 11A3.5 3.5 0 0 0 15 4Z" />
                      </Canvas>
                    </Viewbox>
                  </Border>
                  <TextBlock Text="People" VerticalAlignment="Center" />
                </StackPanel>
              </ListBoxItem>
              <TextBlock Grid.Row="3" Text="Item at bottom" Margin="60,12" />
            </Grid>
          </SplitView.Pane>

          <Grid>
            <TextBlock FontSize="14" FontWeight="700" Text="SplitViewContent" HorizontalAlignment="Center" VerticalAlignment="Center" />
            <TextBlock FontSize="14" FontWeight="700" Text="SplitViewContent" TextAlignment="Left" />
            <TextBlock FontSize="14" FontWeight="700" Text="SplitViewContent" HorizontalAlignment="Right" />
            <TextBlock FontSize="14" FontWeight="700" Text="SplitViewContent" VerticalAlignment="Bottom" />
            <TextBlock FontSize="14" FontWeight="700" Text="SplitViewContent" VerticalAlignment="Bottom" HorizontalAlignment="Right" />
          </Grid>
        </SplitView>
      </Border>
    </Grid>
  </Border>
</UserControl>
