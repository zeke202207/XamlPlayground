<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <StackPanel Orientation="Vertical" Spacing="12">
    <TextBlock Classes="h2">Displays bitmap and vector image assets.</TextBlock>

    <WrapPanel Margin="-8,0" HorizontalAlignment="Center">
      <Border Margin="8" BorderBrush="Gray" BorderThickness="1" Padding="8">
        <StackPanel Spacing="6">
          <TextBlock Text="Uniform" />
          <Image Source="avares://XamlPlayground/Assets/Logo.png" Width="120" Height="120" Stretch="Uniform" />
        </StackPanel>
      </Border>
      <Border Margin="8" BorderBrush="Gray" BorderThickness="1" Padding="8">
        <StackPanel Spacing="6">
          <TextBlock Text="UniformToFill with clip" />
          <Border Width="120" Height="80" ClipToBounds="True" CornerRadius="6">
            <Image Source="avares://XamlPlayground/Assets/Logo.png" Stretch="UniformToFill" />
          </Border>
        </StackPanel>
      </Border>
      <Border Margin="8" BorderBrush="Gray" BorderThickness="1" Padding="8">
        <StackPanel Spacing="6">
          <TextBlock Text="Opacity" />
          <Image Source="avares://XamlPlayground/Assets/Logo.png" Width="120" Height="120" Opacity="0.45" />
        </StackPanel>
      </Border>
    </WrapPanel>
  </StackPanel>
</UserControl>
