<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <DockPanel>
    <StackPanel DockPanel.Dock="Right" Width="220" Margin="12" Spacing="8">
      <TextBlock Text="TabbedPage" FontWeight="SemiBold" FontSize="16" Foreground="{DynamicResource SystemControlHighlightAccentBrush}" />
      <TextBlock TextWrapping="Wrap" Opacity="0.7" Text="A page-oriented tab container with ContentPage children." />
    </StackPanel>

    <Border DockPanel.Dock="Right" Width="1" Background="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" />

    <Border Margin="12"
            BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
            BorderThickness="1"
            CornerRadius="6"
            ClipToBounds="True">
      <TabbedPage TabPlacement="Top">
        <ContentPage Header="Home">
          <StackPanel Margin="16" Spacing="8">
            <TextBlock Text="Home Tab" FontSize="24" FontWeight="Bold" />
            <TextBlock Text="Welcome to the Home tab. This is a TabbedPage sample." TextWrapping="Wrap" />
          </StackPanel>
        </ContentPage>
        <ContentPage Header="Search">
          <StackPanel Margin="16" Spacing="8">
            <TextBlock Text="Search Tab" FontSize="24" FontWeight="Bold" />
            <TextBox PlaceholderText="Type to search..." />
            <TextBlock Text="Search results will appear here." Opacity="0.7" />
          </StackPanel>
        </ContentPage>
        <ContentPage Header="Settings">
          <StackPanel Margin="16" Spacing="8">
            <TextBlock Text="Settings Tab" FontSize="24" FontWeight="Bold" />
            <CheckBox Content="Enable notifications" />
            <CheckBox Content="Dark mode" />
            <CheckBox Content="Auto-save" IsChecked="True" />
          </StackPanel>
        </ContentPage>
      </TabbedPage>
    </Border>
  </DockPanel>
</UserControl>
