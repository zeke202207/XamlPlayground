<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:cp="clr-namespace:Avalonia.Controls;assembly=Avalonia.Controls.ColorPicker"
             xmlns:cpp="clr-namespace:Avalonia.Controls.Primitives;assembly=Avalonia.Controls.ColorPicker">
  <Grid ColumnDefinitions="Auto,20,Auto" RowDefinitions="Auto,Auto">
    <StackPanel Grid.Column="0" Grid.RowSpan="2" Spacing="16">
      <cp:ColorView ColorSpectrumShape="Ring" />
      <cp:ColorPicker HsvColor="hsv(120, 1, 1)">
        <cp:ColorPicker.Palette>
          <cp:FlatHalfColorPalette />
        </cp:ColorPicker.Palette>
      </cp:ColorPicker>
      <cp:ColorPicker HsvColor="hsv(220, 0.85, 0.9)" Width="180" />
    </StackPanel>

    <Grid Grid.Column="2"
          RowDefinitions="Auto,Auto,Auto,Auto,Auto">
      <cpp:ColorSpectrum x:Name="ColorSpectrum1"
                         Grid.Row="0"
                         Color="Red"
                         CornerRadius="10"
                         Height="256"
                         Width="256" />
      <cpp:ColorSlider Grid.Row="1"
                       Margin="0,10,0,0"
                       ColorComponent="Component1"
                       ColorModel="Hsva"
                       HsvColor="{Binding HsvColor, ElementName=ColorSpectrum1}" />
      <cpp:ColorSlider Grid.Row="2"
                       ColorComponent="Component2"
                       ColorModel="Hsva"
                       HsvColor="{Binding HsvColor, ElementName=ColorSpectrum1}" />
      <cpp:ColorSlider Grid.Row="3"
                       ColorComponent="Component3"
                       ColorModel="Hsva"
                       HsvColor="{Binding HsvColor, ElementName=ColorSpectrum1}" />
      <cpp:ColorPreviewer Grid.Row="4"
                          IsAccentColorsVisible="False"
                          HsvColor="{Binding HsvColor, ElementName=ColorSpectrum1}"
                          Margin="0,2,0,0" />
    </Grid>
  </Grid>
</UserControl>
