<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:XamlPlayground.ViewModels"
             xmlns:workspace="clr-namespace:XamlPlayground.Workspace"
             xmlns:visualVm="clr-namespace:XamlPlayground.ViewModels.VisualEditing"
             xmlns:dock="using:Dock.Avalonia.Controls"
             xmlns:views="clr-namespace:XamlPlayground.Views"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="450"
             x:Class="XamlPlayground.Views.MainView"
             x:CompileBindings="True" x:DataType="vm:MainViewModel"
             FontFamily="fonts:Inter#Inter">
  <Design.DataContext>
    <vm:MainViewModel />
  </Design.DataContext>

  <Grid RowDefinitions="Auto,*">
    <views:HeaderView Grid.Row="0" />
    <dock:DockControl Grid.Row="1"
                      Layout="{Binding DockLayout}"
                      Factory="{Binding DockFactory}"
                      InitializeFactory="False"
                      InitializeLayout="False"
                      EnableManagedWindowLayer="True"
                      Margin="4" />

    <Border Grid.RowSpan="2"
            IsVisible="{Binding NewProjectWizard.IsOpen}"
            Background="#66000000"
            ZIndex="1000">
      <Border Width="520"
              MaxWidth="720"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              Background="{DynamicResource DockSurfacePanelBrush}"
              BorderBrush="{DynamicResource EditorBorderBrush}"
              BorderThickness="1"
              Padding="18">
        <StackPanel Spacing="14">
          <TextBlock Text="New Solution"
                     FontSize="20"
                     FontWeight="SemiBold" />
          <Grid RowDefinitions="Auto,Auto,Auto"
                ColumnDefinitions="140,*"
                RowSpacing="10"
                ColumnSpacing="12">
            <TextBlock Text="Solution name:"
                       VerticalAlignment="Center" />
            <TextBox Grid.Column="1"
                     Text="{Binding NewProjectWizard.SolutionName, Mode=TwoWay}" />

            <TextBlock Grid.Row="1"
                       Text="Template:"
                       VerticalAlignment="Center" />
            <ComboBox Grid.Row="1"
                      Grid.Column="1"
                      ItemsSource="{Binding NewProjectWizard.Templates}"
                      SelectedItem="{Binding NewProjectWizard.SelectedTemplate, Mode=TwoWay}">
              <ComboBox.ItemTemplate>
                <DataTemplate DataType="workspace:AvaloniaProjectTemplate">
                  <StackPanel>
                    <TextBlock Text="{Binding Name}" />
                    <TextBlock Text="{Binding ShortName}"
                               Opacity="0.65"
                               FontSize="11" />
                  </StackPanel>
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>

            <TextBlock Grid.Row="2"
                       Grid.Column="1"
                       Text="{Binding NewProjectWizard.SelectedTemplate.Description}"
                       TextWrapping="Wrap"
                       Opacity="0.75" />
          </Grid>

          <TextBlock Text="Templates are modeled from the locally installed Avalonia template set: avalonia.app, avalonia.mvvm, avalonia.xplat."
                     TextWrapping="Wrap"
                     Opacity="0.7" />

          <StackPanel Orientation="Horizontal"
                      HorizontalAlignment="Right"
                      Spacing="8">
            <Button Content="Cancel"
                    Command="{Binding CancelNewProjectCommand}" />
            <Button Content="Create"
                    Command="{Binding CreateProjectCommand}" />
          </StackPanel>
        </StackPanel>
      </Border>
    </Border>

    <Border Grid.RowSpan="2"
            IsVisible="{Binding IsThemeResourceDeleteDialogOpen}"
            Background="#66000000"
            ZIndex="1001">
      <Border Width="760"
              MaxWidth="980"
              MaxHeight="680"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              Background="{DynamicResource DockSurfacePanelBrush}"
              BorderBrush="{DynamicResource EditorBorderBrush}"
              BorderThickness="1"
              Padding="18">
        <Grid RowDefinitions="Auto,Auto,*,Auto"
              RowSpacing="12">
          <TextBlock Text="{Binding ThemeResourceDeleteDialogTitle}"
                     FontSize="20"
                     FontWeight="SemiBold" />
          <TextBlock Grid.Row="1"
                     Text="{Binding ThemeResourceDeleteDialogMessage}"
                     TextWrapping="Wrap"
                     Opacity="0.75" />
          <ListBox Grid.Row="2"
                   ItemsSource="{Binding ThemeResourceDeleteChanges}"
                   SelectedItem="{Binding SelectedThemeResourceDeleteChange, Mode=TwoWay}"
                   MinHeight="260">
            <ListBox.ItemTemplate>
              <DataTemplate DataType="visualVm:ThemeResourceDeleteChangeViewModel"
                            x:DataType="visualVm:ThemeResourceDeleteChangeViewModel">
                <StackPanel Spacing="6"
                            Margin="0,5">
                  <TextBlock Text="{Binding Title}"
                             FontWeight="SemiBold"
                             TextTrimming="CharacterEllipsis" />
                  <TextBlock Text="{Binding Summary}"
                             Opacity="0.65" />
                  <TextBox Text="{Binding Diff}"
                           AcceptsReturn="True"
                           IsReadOnly="True"
                           FontFamily="monospace"
                           MinHeight="120"
                           MaxHeight="260"
                           ScrollViewer.HorizontalScrollBarVisibility="Auto"
                           ScrollViewer.VerticalScrollBarVisibility="Auto" />
                </StackPanel>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
          <StackPanel Grid.Row="3"
                      Orientation="Horizontal"
                      HorizontalAlignment="Right"
                      Spacing="8">
            <Button Content="Cancel"
                    Command="{Binding CancelThemeResourceDeleteCommand}" />
            <Button Content="Delete"
                    Command="{Binding ConfirmThemeResourceDeleteCommand}" />
          </StackPanel>
        </Grid>
      </Border>
    </Border>
  </Grid>
</UserControl>
