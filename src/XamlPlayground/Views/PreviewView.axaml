<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:XamlPlayground.Controls"
             xmlns:vm="clr-namespace:XamlPlayground.ViewModels"
             mc:Ignorable="d" d:DesignWidth="700" d:DesignHeight="48"
             x:Class="XamlPlayground.Views.PreviewView"
             x:CompileBindings="True" x:DataType="vm:MainViewModel">
  <Design.DataContext>
    <vm:MainViewModel />
  </Design.DataContext>
  <ScrollViewer HorizontalScrollBarVisibility="Auto"
                VerticalScrollBarVisibility="Auto"
                DragDrop.AllowDrop="{Binding VisualEditorDesignerMode}">
    <Grid x:Name="PreviewSurface">
      <controls:ExclusiveContentControl x:Name="PreviewContentHost"
                                        IsVisible="{Binding IsInProcessPreviewActive}"
                                        IsHitTestVisible="{Binding VisualEditorPreviewContentHitTestVisible}"
                                        Source="{Binding Control}" />
      <Border IsVisible="{Binding IsRemotePreviewActive}"
              Background="{DynamicResource DockSurfacePanelBrush}"
              Padding="0">
        <Image Source="{Binding RemotePreviewBitmap}"
               HorizontalAlignment="Left"
               VerticalAlignment="Top"
               Stretch="None" />
      </Border>
      <Canvas x:Name="DesignerOverlay"
              Panel.ZIndex="10000"
              Background="Transparent"
              Focusable="True"
              IsVisible="{Binding VisualEditorDesignerMode}"
              IsHitTestVisible="{Binding VisualEditorDesignerMode}">
        <Border IsVisible="{Binding VisualEditorPreviewDropTargetVisible}"
                Canvas.Left="{Binding VisualEditorPreviewDropTargetLeft}"
                Canvas.Top="{Binding VisualEditorPreviewDropTargetTop}"
                Width="{Binding VisualEditorPreviewDropTargetWidth}"
                Height="{Binding VisualEditorPreviewDropTargetHeight}"
                BorderBrush="#8B5CF6"
                BorderThickness="2"
                Background="#148B5CF6"
                IsHitTestVisible="False" />
        <Border IsVisible="{Binding VisualEditorPreviewInsertionVisible}"
                Canvas.Left="{Binding VisualEditorPreviewInsertionLeft}"
                Canvas.Top="{Binding VisualEditorPreviewInsertionTop}"
                Width="{Binding VisualEditorPreviewInsertionWidth}"
                Height="{Binding VisualEditorPreviewInsertionHeight}"
                Background="#0078D4"
                BorderBrush="White"
                BorderThickness="1"
                IsHitTestVisible="False" />
        <Border IsVisible="{Binding VisualEditorPreviewDropPlaceholderVisible}"
                Canvas.Left="{Binding VisualEditorPreviewDropPlaceholderLeft}"
                Canvas.Top="{Binding VisualEditorPreviewDropPlaceholderTop}"
                Width="{Binding VisualEditorPreviewDropPlaceholderWidth}"
                Height="{Binding VisualEditorPreviewDropPlaceholderHeight}"
                Background="#240078D4"
                BorderBrush="#0078D4"
                BorderThickness="2"
                IsHitTestVisible="False" />
        <Border IsVisible="{Binding VisualEditorPreviewVerticalGuideVisible}"
                Canvas.Left="{Binding VisualEditorPreviewVerticalGuideLeft}"
                Canvas.Top="{Binding VisualEditorPreviewVerticalGuideTop}"
                Width="1"
                Height="{Binding VisualEditorPreviewVerticalGuideHeight}"
                Background="#FF00C7B7"
                IsHitTestVisible="False" />
        <Border IsVisible="{Binding VisualEditorPreviewHorizontalGuideVisible}"
                Canvas.Left="{Binding VisualEditorPreviewHorizontalGuideLeft}"
                Canvas.Top="{Binding VisualEditorPreviewHorizontalGuideTop}"
                Width="{Binding VisualEditorPreviewHorizontalGuideWidth}"
                Height="1"
                Background="#FF00C7B7"
                IsHitTestVisible="False" />
        <Border IsVisible="{Binding VisualEditorPreviewMeasurementVisible}"
                Canvas.Left="{Binding VisualEditorPreviewMeasurementLeft}"
                Canvas.Top="{Binding VisualEditorPreviewMeasurementTop}"
                Background="#E6000000"
                CornerRadius="2"
                Padding="4,2"
                IsHitTestVisible="False">
          <TextBlock Text="{Binding VisualEditorPreviewMeasurementText}"
                     Foreground="White"
                     FontSize="11" />
        </Border>
        <Border IsVisible="{Binding VisualEditorPreviewCurrentContainerVisible}"
                Canvas.Left="{Binding VisualEditorPreviewCurrentContainerLeft}"
                Canvas.Top="{Binding VisualEditorPreviewCurrentContainerTop}"
                Width="{Binding VisualEditorPreviewCurrentContainerWidth}"
                Height="{Binding VisualEditorPreviewCurrentContainerHeight}"
                BorderBrush="#10B981"
                BorderThickness="1"
                Background="#0810B981"
                IsHitTestVisible="False" />
        <Border IsVisible="{Binding VisualEditorPreviewSelectionVisible}"
                Canvas.Left="{Binding VisualEditorPreviewSelectionLeft}"
                Canvas.Top="{Binding VisualEditorPreviewSelectionTop}"
                Width="{Binding VisualEditorPreviewSelectionWidth}"
                Height="{Binding VisualEditorPreviewSelectionHeight}"
                BorderBrush="#0078D4"
                BorderThickness="2"
                Background="#120078D4"
                IsHitTestVisible="False" />
        <Border IsVisible="{Binding VisualEditorPreviewSelectionVisible}"
                Name="ResizeNorthWestThumb"
                Canvas.Left="{Binding VisualEditorPreviewNorthWestThumbLeft}"
                Canvas.Top="{Binding VisualEditorPreviewNorthWestThumbTop}"
                Width="{Binding VisualEditorPreviewThumbSize}"
                Height="{Binding VisualEditorPreviewThumbSize}"
                Background="#0078D4"
                BorderBrush="White"
                BorderThickness="1"
                IsHitTestVisible="True" />
        <Border IsVisible="{Binding VisualEditorPreviewSelectionVisible}"
                Name="ResizeNorthThumb"
                Canvas.Left="{Binding VisualEditorPreviewNorthThumbLeft}"
                Canvas.Top="{Binding VisualEditorPreviewNorthThumbTop}"
                Width="{Binding VisualEditorPreviewThumbSize}"
                Height="{Binding VisualEditorPreviewThumbSize}"
                Background="#0078D4"
                BorderBrush="White"
                BorderThickness="1"
                IsHitTestVisible="True" />
        <Border IsVisible="{Binding VisualEditorPreviewSelectionVisible}"
                Name="ResizeNorthEastThumb"
                Canvas.Left="{Binding VisualEditorPreviewNorthEastThumbLeft}"
                Canvas.Top="{Binding VisualEditorPreviewNorthEastThumbTop}"
                Width="{Binding VisualEditorPreviewThumbSize}"
                Height="{Binding VisualEditorPreviewThumbSize}"
                Background="#0078D4"
                BorderBrush="White"
                BorderThickness="1"
                IsHitTestVisible="True" />
        <Border IsVisible="{Binding VisualEditorPreviewSelectionVisible}"
                Name="ResizeWestThumb"
                Canvas.Left="{Binding VisualEditorPreviewWestThumbLeft}"
                Canvas.Top="{Binding VisualEditorPreviewWestThumbTop}"
                Width="{Binding VisualEditorPreviewThumbSize}"
                Height="{Binding VisualEditorPreviewThumbSize}"
                Background="#0078D4"
                BorderBrush="White"
                BorderThickness="1"
                IsHitTestVisible="True" />
        <Border IsVisible="{Binding VisualEditorPreviewSelectionVisible}"
                Name="ResizeEastThumb"
                Canvas.Left="{Binding VisualEditorPreviewEastThumbLeft}"
                Canvas.Top="{Binding VisualEditorPreviewEastThumbTop}"
                Width="{Binding VisualEditorPreviewThumbSize}"
                Height="{Binding VisualEditorPreviewThumbSize}"
                Background="#0078D4"
                BorderBrush="White"
                BorderThickness="1"
                IsHitTestVisible="True" />
        <Border IsVisible="{Binding VisualEditorPreviewSelectionVisible}"
                Name="ResizeSouthWestThumb"
                Canvas.Left="{Binding VisualEditorPreviewSouthWestThumbLeft}"
                Canvas.Top="{Binding VisualEditorPreviewSouthWestThumbTop}"
                Width="{Binding VisualEditorPreviewThumbSize}"
                Height="{Binding VisualEditorPreviewThumbSize}"
                Background="#0078D4"
                BorderBrush="White"
                BorderThickness="1"
                IsHitTestVisible="True" />
        <Border IsVisible="{Binding VisualEditorPreviewSelectionVisible}"
                Name="ResizeSouthThumb"
                Canvas.Left="{Binding VisualEditorPreviewSouthThumbLeft}"
                Canvas.Top="{Binding VisualEditorPreviewSouthThumbTop}"
                Width="{Binding VisualEditorPreviewThumbSize}"
                Height="{Binding VisualEditorPreviewThumbSize}"
                Background="#0078D4"
                BorderBrush="White"
                BorderThickness="1"
                IsHitTestVisible="True" />
        <Border IsVisible="{Binding VisualEditorPreviewSelectionVisible}"
                Name="ResizeSouthEastThumb"
                Canvas.Left="{Binding VisualEditorPreviewSouthEastThumbLeft}"
                Canvas.Top="{Binding VisualEditorPreviewSouthEastThumbTop}"
                Width="{Binding VisualEditorPreviewThumbSize}"
                Height="{Binding VisualEditorPreviewThumbSize}"
                Background="#0078D4"
                BorderBrush="White"
                BorderThickness="1"
                IsHitTestVisible="True" />
      </Canvas>
    </Grid>
  </ScrollViewer>
</UserControl>
