<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:XamlPlayground.ViewModels"
             xmlns:minimap="using:XamlPlayground.Editor.Minimap"
             xmlns:inline="using:XamlPlayground.Services.Editing.InlineFeatures"
             xmlns:diag="using:Avalonia.Diagnostics"
             xmlns:i="clr-namespace:Avalonia.Xaml.Interactivity;assembly=Xaml.Behaviors.Interactivity"
             xmlns:behaviors="clr-namespace:XamlPlayground.Behaviors"
             mc:Ignorable="d" d:DesignWidth="450" d:DesignHeight="450"
             x:Class="XamlPlayground.Views.CodeView"
             x:CompileBindings="True" x:DataType="vm:MainViewModel">
  <Design.DataContext>
    <vm:MainViewModel />
  </Design.DataContext>
  
  <UserControl.Styles>
    <Style Selector="TabControl.code TabItem">
      <Setter Property="MinHeight" Value="32" />
      <Setter Property="Margin" Value="12,2,2,2" />
      <Setter Property="Padding" Value="8" />
      <Setter Property="(TextBlock.FontSize)" Value="16" />
    </Style>
    <Style Selector="TabControl.code TabItem /template/ Border#PART_LayoutRoot">
      <Setter Property="Margin" Value="0 0 0 0" />
    </Style>
    <Style Selector="TabControl.code">
      <Setter Property="Padding" Value="0" />
    </Style>
  </UserControl.Styles>
  
  <Grid>
    <TabControl TabStripPlacement="Bottom" Classes="code" BorderBrush="{DynamicResource EditorBorderBrush}" BorderThickness="0,0,1,0">
      <TabControl.Styles>
        <Style Selector="TabControl">
          <Setter Property="Padding" Value="0" />
        </Style>
        <Style Selector="TabItem">
          <Setter Property="Padding" Value="6"/>
          <Setter Property="FontSize" Value="{DynamicResource FontSizeNormal}" />
        </Style>
      </TabControl.Styles>
      <TabItem Header="Xaml">
        <minimap:MinimapTextEditor Margin="0"
                                   Classes="theme-aware"
                                   IsReadOnly="{OnFormFactor False, Mobile=True}"
                                   behaviors:TextEditorDocument.Document="{Binding CurrentSample.Xaml}"
                                   inline:PlaygroundInlineFeatures.Mode="SampleXaml"
                                   inline:PlaygroundInlineFeatures.Shell="{Binding}"
                                   HorizontalScrollBarVisibility="Auto"
                                   VerticalScrollBarVisibility="Auto"
                                   FontFamily="avares://XamlPlayground/Assets/Fonts#Roboto Mono"
                                   ShowLineNumbers="True"
                                   FontWeight="Normal"
                                   FontSize="{Binding EditorFontSize}"
                                   WordWrap="False"
                                   MinimapLanguage="xaml">
          <i:Interaction.Behaviors>
            <behaviors:TextEditorBehavior Extension=".xml" />
          </i:Interaction.Behaviors>
        </minimap:MinimapTextEditor>
      </TabItem>
      <TabItem Header="Code">
        <minimap:MinimapTextEditor Margin="0"
                                   Classes="theme-aware"
                                   IsReadOnly="{OnFormFactor False, Mobile=True}"
                                   behaviors:TextEditorDocument.Document="{Binding CurrentSample.Code}"
                                   inline:PlaygroundInlineFeatures.Mode="SampleCode"
                                   inline:PlaygroundInlineFeatures.Shell="{Binding}"
                                   HorizontalScrollBarVisibility="Auto"
                                   VerticalScrollBarVisibility="Auto"
                                   FontFamily="avares://XamlPlayground/Assets/Fonts#Roboto Mono"
                                   ShowLineNumbers="True"
                                   FontWeight="Normal"
                                   FontSize="{Binding EditorFontSize}"
                                   WordWrap="False"
                                   MinimapLanguage="csharp">
          <i:Interaction.Behaviors>
            <behaviors:TextEditorBehavior Extension=".cs" />
          </i:Interaction.Behaviors>
        </minimap:MinimapTextEditor>
      </TabItem>
      <TabItem Header="Diagnostics">
        <diag:DevToolsView Root="{Binding DiagnosticsRoot}">
          <diag:DevToolsView.Options>
            <diag:DevToolsOptions ShowMenu="False"
                                  ShowResourcesTab="False"
                                  ShowAssetsTab="False"
                                  ScopeEventsToRoot="True" />
          </diag:DevToolsView.Options>
        </diag:DevToolsView>
      </TabItem>
    </TabControl>

    <TextBox Text="{Binding LastErrorMessage}"
             IsVisible="{Binding !!LastErrorMessage}"
             IsReadOnly="True"
             AcceptsReturn="True"
             TextWrapping="Wrap"
             ScrollViewer.VerticalScrollBarVisibility="Auto"
             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
             Background="Red"
             Foreground="White"
             BorderThickness="0"
             Padding="4"
             MaxHeight="120"
             Margin="0,0,0,36"
             VerticalAlignment="Bottom" />
  </Grid>
</UserControl>
