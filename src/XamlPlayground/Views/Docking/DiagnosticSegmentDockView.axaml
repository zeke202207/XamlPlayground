<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:diag="using:Avalonia.Diagnostics"
             xmlns:vm="clr-namespace:XamlPlayground.ViewModels.Docking"
             mc:Ignorable="d" d:DesignWidth="320" d:DesignHeight="260"
             x:Class="XamlPlayground.Views.Docking.DiagnosticSegmentDockView"
             x:CompileBindings="True" x:DataType="vm:DiagnosticSegmentDockViewModel">
  <diag:DevToolsSegmentView Session="{Binding Session}"
                            ViewKind="{Binding ViewKind}"
                            SegmentKind="{Binding SegmentKind}" />
</UserControl>
