<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:diag="using:Avalonia.Diagnostics"
             xmlns:vm="clr-namespace:XamlPlayground.ViewModels.Docking"
             mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="260"
             x:Class="XamlPlayground.Views.Docking.DiagnosticsDockView"
             x:CompileBindings="True" x:DataType="vm:DiagnosticToolDockViewModel">
  <diag:DevToolsView Root="{Binding Shell.DiagnosticsRoot}"
                     ViewKind="{Binding ViewKind}">
    <diag:DevToolsView.Options>
      <diag:DevToolsOptions ShowMenu="False"
                            ShowResourcesTab="False"
                            ShowAssetsTab="False"
                            ShowEventsTab="False"
                            ScopeEventsToRoot="True" />
    </diag:DevToolsView.Options>
  </diag:DevToolsView>
</UserControl>
