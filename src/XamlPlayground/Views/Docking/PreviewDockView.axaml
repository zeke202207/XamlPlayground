<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:views="clr-namespace:XamlPlayground.Views"
             xmlns:vm="clr-namespace:XamlPlayground.ViewModels.Docking"
             mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="500"
             x:Class="XamlPlayground.Views.Docking.PreviewDockView"
             x:CompileBindings="True" x:DataType="vm:PreviewDockViewModel">
  <DockPanel Background="{DynamicResource DockSurfacePanelBrush}">
    <Border DockPanel.Dock="Top"
            BorderThickness="0,0,0,1"
            BorderBrush="{DynamicResource EditorBorderBrush}"
            Padding="6">
      <StackPanel Orientation="Horizontal"
                  Spacing="8">
        <ToggleButton Content="Design mode"
                      IsChecked="{Binding Shell.VisualEditorDesignerMode, Mode=TwoWay}"
                      ToolTip.Tip="Enable designer selection, drag, resize, and drop gestures." />
        <TextBlock Text="{Binding Shell.VisualEditorSelectedElementTitle}"
                   VerticalAlignment="Center"
                   TextTrimming="CharacterEllipsis"
                   Opacity="0.75" />
        <TextBlock Text="in"
                   VerticalAlignment="Center"
                   Opacity="0.55" />
        <TextBlock Text="{Binding Shell.VisualEditorCurrentContainerTitle}"
                   VerticalAlignment="Center"
                   TextTrimming="CharacterEllipsis"
                   Opacity="0.75" />
      </StackPanel>
    </Border>

    <views:PreviewView DataContext="{Binding Shell}" />
  </DockPanel>
</UserControl>
