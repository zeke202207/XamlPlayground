<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ae="clr-namespace:AvaloniaEdit;assembly=AvaloniaEdit"
             xmlns:i="clr-namespace:Avalonia.Xaml.Interactivity;assembly=Xaml.Behaviors.Interactivity"
             xmlns:behaviors="clr-namespace:XamlPlayground.Behaviors"
             xmlns:vm="clr-namespace:XamlPlayground.ViewModels.Docking"
             mc:Ignorable="d" d:DesignWidth="500" d:DesignHeight="500"
             x:Class="XamlPlayground.Views.Docking.XamlEditorDockView"
             x:CompileBindings="True" x:DataType="vm:XamlEditorDockViewModel">
  <ae:TextEditor Margin="0"
                 Classes="theme-aware"
                 IsReadOnly="{OnFormFactor False, Mobile=True}"
                 behaviors:TextEditorDocument.Document="{Binding Shell.CurrentSample.Xaml}"
                 HorizontalScrollBarVisibility="Auto"
                 VerticalScrollBarVisibility="Auto"
                 FontFamily="avares://XamlPlayground/Assets/Fonts#Roboto Mono"
                 ShowLineNumbers="True"
                 FontWeight="Normal"
                 FontSize="{Binding Shell.EditorFontSize}"
                 WordWrap="False">
    <i:Interaction.Behaviors>
      <behaviors:TextEditorBehavior Extension=".xml" />
    </i:Interaction.Behaviors>
  </ae:TextEditor>
</UserControl>
