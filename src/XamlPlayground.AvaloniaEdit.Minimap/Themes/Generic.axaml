<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:minimap="using:XamlPlayground.Editor.Minimap">
  <Styles.Resources>
    <ResourceDictionary>
      <ControlTheme x:Key="{x:Type minimap:MinimapTextEditor}" TargetType="minimap:MinimapTextEditor">
        <Setter Property="Template">
          <ControlTemplate>
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}">
              <Grid ColumnDefinitions="Auto,*,Auto">
                <minimap:TextEditorMinimap Name="PART_LeftMinimap"
                                           Grid.Column="0"
                                           Background="{TemplateBinding MinimapBackground}"
                                           MinimapEnabled="{TemplateBinding MinimapEnabled}"
                                           AutoHide="{TemplateBinding MinimapAutoHide}"
                                           SizeMode="{TemplateBinding MinimapSize}"
                                           ShowSlider="{TemplateBinding MinimapShowSlider}"
                                           RenderCharacters="{TemplateBinding MinimapRenderCharacters}"
                                           MaxColumn="{TemplateBinding MinimapMaxColumn}"
                                           Scale="{TemplateBinding MinimapScale}"
                                           ShowRegionSectionHeaders="{TemplateBinding MinimapShowRegionSectionHeaders}"
                                           ShowMarkSectionHeaders="{TemplateBinding MinimapShowMarkSectionHeaders}"
                                           MarkSectionHeaderRegex="{TemplateBinding MinimapMarkSectionHeaderRegex}"
                                           SectionHeaderFontSize="{TemplateBinding MinimapSectionHeaderFontSize}"
                                           SectionHeaderLetterSpacing="{TemplateBinding MinimapSectionHeaderLetterSpacing}"
                                           Language="{TemplateBinding MinimapLanguage}"
                                           TextBrush="{TemplateBinding MinimapForeground}"
                                           CommentBrush="{TemplateBinding MinimapCommentBrush}"
                                           KeywordBrush="{TemplateBinding MinimapKeywordBrush}"
                                           StringBrush="{TemplateBinding MinimapStringBrush}"
                                           TagBrush="{TemplateBinding MinimapTagBrush}"
                                           SliderBrush="{TemplateBinding MinimapSliderBrush}"
                                           SliderPointerOverBrush="{TemplateBinding MinimapSliderPointerOverBrush}"
                                           SectionHeaderForeground="{TemplateBinding MinimapSectionHeaderForeground}"
                                           SectionHeaderSeparatorBrush="{TemplateBinding MinimapSectionHeaderSeparatorBrush}" />
                <ScrollViewer Focusable="False"
                              Name="PART_ScrollViewer"
                              Grid.Column="1"
                              VerticalScrollBarVisibility="{TemplateBinding VerticalScrollBarVisibility}"
                              HorizontalScrollBarVisibility="{TemplateBinding HorizontalScrollBarVisibility}"
                              VerticalContentAlignment="Top"
                              HorizontalContentAlignment="Left"
                              Padding="{TemplateBinding Padding}" />
                <minimap:TextEditorMinimap Name="PART_RightMinimap"
                                           Grid.Column="2"
                                           Background="{TemplateBinding MinimapBackground}"
                                           MinimapEnabled="{TemplateBinding MinimapEnabled}"
                                           AutoHide="{TemplateBinding MinimapAutoHide}"
                                           SizeMode="{TemplateBinding MinimapSize}"
                                           ShowSlider="{TemplateBinding MinimapShowSlider}"
                                           RenderCharacters="{TemplateBinding MinimapRenderCharacters}"
                                           MaxColumn="{TemplateBinding MinimapMaxColumn}"
                                           Scale="{TemplateBinding MinimapScale}"
                                           ShowRegionSectionHeaders="{TemplateBinding MinimapShowRegionSectionHeaders}"
                                           ShowMarkSectionHeaders="{TemplateBinding MinimapShowMarkSectionHeaders}"
                                           MarkSectionHeaderRegex="{TemplateBinding MinimapMarkSectionHeaderRegex}"
                                           SectionHeaderFontSize="{TemplateBinding MinimapSectionHeaderFontSize}"
                                           SectionHeaderLetterSpacing="{TemplateBinding MinimapSectionHeaderLetterSpacing}"
                                           Language="{TemplateBinding MinimapLanguage}"
                                           TextBrush="{TemplateBinding MinimapForeground}"
                                           CommentBrush="{TemplateBinding MinimapCommentBrush}"
                                           KeywordBrush="{TemplateBinding MinimapKeywordBrush}"
                                           StringBrush="{TemplateBinding MinimapStringBrush}"
                                           TagBrush="{TemplateBinding MinimapTagBrush}"
                                           SliderBrush="{TemplateBinding MinimapSliderBrush}"
                                           SliderPointerOverBrush="{TemplateBinding MinimapSliderPointerOverBrush}"
                                           SectionHeaderForeground="{TemplateBinding MinimapSectionHeaderForeground}"
                                           SectionHeaderSeparatorBrush="{TemplateBinding MinimapSectionHeaderSeparatorBrush}" />
              </Grid>
            </Border>
          </ControlTemplate>
        </Setter>
      </ControlTheme>
    </ResourceDictionary>
  </Styles.Resources>
</Styles>
